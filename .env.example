# ─── Server ───────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ─── MongoDB ──────────────────────────────────────────────
# Get from https://cloud.mongodb.com → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/whoowes?retryWrites=true&w=majority

# ─── JWT ──────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here
JWT_EXPIRES_IN=30d

# ─── CORS ─────────────────────────────────────────────────
# Comma-separated list of allowed origins (leave blank to allow all)
ALLOWED_ORIGINS=
